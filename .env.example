# Admin credentials for login (from .env)
ADMIN_EMAIL=admin@.cadminom
ADMIN_PASSWORD=your-secure-password

# Supabase (get from https://supabase.com/dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Service role key for server-side admin operations (bypasses RLS)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Auth secret for session cookie (generate with: openssl rand -base64 32)
AUTH_SECRET=your-random-secret-for-session-encryption
